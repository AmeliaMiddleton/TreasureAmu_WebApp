{
  // Staging logging — more verbose than production to aid debugging.
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Supabase credentials are NOT stored here.
  // Set them as Application Settings in the staging Azure App Service:
  //   Supabase__Url              → your staging Supabase project URL
  //   Supabase__AnonKey          → your staging Supabase anon key
  //   Supabase__ServiceRoleKey   → your staging Supabase service role key

  "AllowedHosts": "treasureamu-staging.azurewebsites.net",

  "AllowedOrigins": [
    "https://treasureamu-staging.pages.dev"
  ]
}
