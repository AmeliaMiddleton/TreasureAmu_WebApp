{
  // Production logging — warnings and errors only, no verbose debug output.
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  // Supabase credentials are NOT stored here.
  // Set them as Application Settings in Azure Portal:
  //   Supabase__Url              → your Supabase project URL
  //   Supabase__AnonKey          → your Supabase anon key
  //   Supabase__ServiceRoleKey   → your Supabase service role key
  //
  // Azure maps double-underscore (__) to the colon (:) used in .NET config sections,
  // so "Supabase__Url" becomes "Supabase:Url" at runtime — no code changes needed.

  "AllowedHosts": "treasureamu.azurewebsites.net;api.treasureamu.com",

  // Production: AllowedOrigins overrides appsettings.json to exclude
  // http://localhost:4200 (a dev-only origin that must never be permitted in
  // production) and to include all live frontend domains.
  "AllowedOrigins": [
    "https://treasureamu.com",
    "https://www.treasureamu.com",
    "https://treasureamu.store",
    "https://www.treasureamu.store",
    "https://geekamu.com",
    "https://www.geekamu.com"
  ]
}
